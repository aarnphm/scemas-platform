# database
DATABASE_URL=postgres://scemas:scemas@localhost:5432/scemas
# neon (production postgres, for schema management only)
NEON_DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/scemas?sslmode=require

# rust server
RUST_PORT=3001
RUST_LOG=info

# auth (default accounts are bootstrapped during bun db:push)
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
DEVICE_AUTH_SECRET=change-me-device-ingest-secret
DEVICE_CATALOG_PATH=data/hamilton-sensor-catalog.json

# next.js
NEXT_PUBLIC_API_URL=http://localhost:3000
INTERNAL_RUST_URL=http://localhost:3001

# cloudflare (set as github repo secrets for CI deploy)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
