{
  "name": "@scemas/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "ensure-users": "bun run scripts/ensure-users.ts",
    "sync-desktop-schema": "bun run scripts/sync-desktop-schema.ts",
    "generate": "drizzle-kit generate",
    "push": "drizzle-kit push 2>&1 | sed $'s/\\x1b\\[[0-9;]*[A-Za-z]//g'",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
