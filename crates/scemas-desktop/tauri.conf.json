{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-web/main/.schemas/tauri-conf.schema.json",
  "identifier": "dev.scemas.desktop",
  "build": {
    "frontendDist": "../../packages/desktop/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun --filter @scemas/desktop build",
    "beforeDevCommand": "bun --filter @scemas/desktop dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SCEMAS - Environmental Monitoring",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/schema.sql",
      "../../data/hamilton-sensor-catalog.json"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/aarnphm/scemas-platform/releases/latest/download/latest.json"
      ],
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": ["scemas"]
      }
    }
  }
}
